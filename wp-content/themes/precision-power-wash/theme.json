{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        { "slug": "ink",        "color": "#050d1a", "name": "Ink" },
        { "slug": "navy",       "color": "#0a1628", "name": "Navy" },
        { "slug": "steel",      "color": "#132238", "name": "Steel" },
        { "slug": "blue-deep",  "color": "#1a3a5c", "name": "Blue Deep" },
        { "slug": "blue-mid",   "color": "#1e4976", "name": "Blue Mid" },
        { "slug": "cyan",       "color": "#00b4d8", "name": "Cyan" },
        { "slug": "cyan-light", "color": "#48cae4", "name": "Cyan Light" },
        { "slug": "slate",      "color": "#4a5568", "name": "Slate" },
        { "slug": "mist",       "color": "#a0b0c8", "name": "Mist" },
        { "slug": "white",      "color": "#ffffff", "name": "White" },
        { "slug": "off-white",  "color": "#e8f0fe", "name": "Off White" }
      ],
      "gradients": [
        {
          "slug": "hero-dark",
          "gradient": "linear-gradient(160deg, #050d1a 0%, #0a1628 50%, #132238 100%)",
          "name": "Hero Dark"
        },
        {
          "slug": "cyan-glow",
          "gradient": "linear-gradient(135deg, #00b4d8 0%, #0096c7 100%)",
          "name": "Cyan Glow"
        },
        {
          "slug": "section-dark",
          "gradient": "linear-gradient(180deg, #0a1628 0%, #050d1a 100%)",
          "name": "Section Dark"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif",
          "slug": "inter",
          "name": "Inter"
        },
        {
          "fontFamily": "'Barlow Condensed', 'Arial Narrow', sans-serif",
          "slug": "barlow-condensed",
          "name": "Barlow Condensed"
        },
        {
          "fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
          "slug": "mono",
          "name": "Mono"
        }
      ],
      "fontSizes": [
        { "slug": "xs",     "size": "0.75rem",  "name": "XS",     "fluid": false },
        { "slug": "sm",     "size": "0.875rem", "name": "Small",  "fluid": false },
        { "slug": "base",   "size": "1rem",     "name": "Base",   "fluid": false },
        { "slug": "md",     "size": "1.125rem", "name": "Medium", "fluid": false },
        { "slug": "lg",     "size": "1.25rem",  "name": "Large",  "fluid": false },
        { "slug": "xl",     "size": "1.5rem",   "name": "XL",     "fluid": { "min": "1.25rem", "max": "1.5rem" } },
        { "slug": "2xl",    "size": "2rem",     "name": "2XL",    "fluid": { "min": "1.5rem",  "max": "2rem"   } },
        { "slug": "3xl",    "size": "2.5rem",   "name": "3XL",    "fluid": { "min": "1.75rem", "max": "2.5rem" } },
        { "slug": "4xl",    "size": "3.5rem",   "name": "4XL",    "fluid": { "min": "2.25rem", "max": "3.5rem" } },
        { "slug": "display","size": "5.5rem",   "name": "Display","fluid": { "min": "2.75rem", "max": "5.5rem" } }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingSizes": [
        { "slug": "1",  "size": "0.25rem", "name": "1" },
        { "slug": "2",  "size": "0.5rem",  "name": "2" },
        { "slug": "3",  "size": "0.75rem", "name": "3" },
        { "slug": "4",  "size": "1rem",    "name": "4" },
        { "slug": "5",  "size": "1.25rem", "name": "5" },
        { "slug": "6",  "size": "1.5rem",  "name": "6" },
        { "slug": "8",  "size": "2rem",    "name": "8" },
        { "slug": "10", "size": "2.5rem",  "name": "10" },
        { "slug": "12", "size": "3rem",    "name": "12" },
        { "slug": "16", "size": "4rem",    "name": "16" },
        { "slug": "20", "size": "5rem",    "name": "20" },
        { "slug": "24", "size": "6rem",    "name": "24" },
        { "slug": "32", "size": "8rem",    "name": "32" },
        { "slug": "40", "size": "10rem",   "name": "40" }
      ]
    },
    "layout": {
      "contentSize": "72rem",
      "wideSize": "90rem"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "glow-cyan",  "shadow": "0 0 24px rgba(0,180,216,0.35), 0 0 60px rgba(0,180,216,0.15)", "name": "Cyan Glow" },
        { "slug": "glow-blue",  "shadow": "0 0 32px rgba(26,58,92,0.8)", "name": "Blue Glow" },
        { "slug": "card",       "shadow": "0 4px 24px rgba(0,0,0,0.4)", "name": "Card" },
        { "slug": "card-hover", "shadow": "0 8px 40px rgba(0,0,0,0.6), 0 0 24px rgba(0,180,216,0.2)", "name": "Card Hover" }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "palette": [
            { "slug": "cyan",  "color": "#00b4d8", "name": "Cyan" },
            { "slug": "white", "color": "#ffffff", "name": "White" }
          ]
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#050d1a",
      "text": "#e8f0fe"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--8)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--display)",
          "fontWeight": "800",
          "lineHeight": "1.05",
          "letterSpacing": "-0.03em"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--4xl)",
          "fontWeight": "700",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--2xl)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": { "text": "#00b4d8" },
        ":hover": { "color": { "text": "#48cae4" } }
      },
      "button": {
        "border": { "radius": "0.375rem" },
        "color": {
          "background": "#00b4d8",
          "text": "#050d1a"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "fontSize": "var(--wp--preset--font-size--sm)",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--3)",
            "bottom": "var(--wp--preset--spacing--3)",
            "left": "var(--wp--preset--spacing--8)",
            "right": "var(--wp--preset--spacing--8)"
          }
        }
      }
    },
    "blocks": {
      "core/group": {
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--4)",
            "bottom": "var(--wp--preset--spacing--4)"
          }
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "500",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        },
        "color": { "text": "#e8f0fe" }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontSize": "var(--wp--preset--font-size--lg)",
          "fontWeight": "800",
          "letterSpacing": "-0.02em"
        },
        "color": { "text": "#ffffff" }
      }
    }
  },
  "templateParts": [
    { "area": "header", "name": "header", "title": "Header" },
    { "area": "footer", "name": "footer", "title": "Footer" }
  ],
  "customTemplates": [
    { "name": "front-page", "title": "Front Page", "postTypes": ["page"] },
    { "name": "page-quote", "title": "Request a Quote", "postTypes": ["page"] }
  ]
}
