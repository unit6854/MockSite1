{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/wp-content/themes/precision-power-wash/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/wp-includes/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/wp-content/themes/precision-power-wash/assets/images/og-image.svg",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml" }
      ]
    },
    {
      "source": "/wp-content/themes/precision-power-wash/assets/images/favicon.svg",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml" }
      ]
    }
  ]
}
